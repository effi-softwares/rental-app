{
	"name": "rental-app",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev --port 4500",
		"build": "next build",
		"start": "next start",
		"lint": "pnpm run lint:query-keys && pnpm run lint:routes && biome check",
		"lint:fix": "biome check --write",
		"lint:query-keys": "node ./scripts/check-query-keys.mjs",
		"lint:routes": "node ./scripts/check-route-literals.mjs",
		"auth:generate": "pnpm dlx @better-auth/cli@latest generate --config ./lib/auth.ts --output ./lib/db/schema/auth.ts --yes && node ./scripts/patch-auth-schema-uuid.mjs && node ./scripts/verify-auth-schema-uuid.mjs",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"db:seed:vehicles": "node ./scripts/seed-vehicle-lookup.mjs"
	},
	"dependencies": {
		"@base-ui/react": "^1.2.0",
		"@better-auth/passkey": "^1.4.20",
		"@better-auth/stripe": "^1.5.4",
		"@ncdai/react-wheel-picker": "^1.2.0",
		"@neondatabase/serverless": "^1.0.2",
		"@stripe/react-stripe-js": "^5.6.1",
		"@stripe/stripe-js": "^8.9.0",
		"@tanstack/react-form": "^1.28.3",
		"@tanstack/react-query": "^5.90.21",
		"@tanstack/react-table": "^8.21.3",
		"@types/ws": "^8.18.1",
		"@vercel/blob": "^2.3.0",
		"avvvatars-react": "^0.4.2",
		"better-auth": "^1.4.20",
		"boring-avatars": "^2.0.4",
		"bufferutil": "^4.1.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"drizzle-orm": "^0.45.1",
		"lucide-react": "^0.575.0",
		"maplibre-gl": "^5.19.0",
		"next": "16.1.6",
		"next-themes": "^0.4.6",
		"qrcode": "^1.5.4",
		"radix-ui": "^1.4.3",
		"react": "19.2.3",
		"react-dom": "19.2.3",
		"react-easy-crop": "^5.5.6",
		"recharts": "^3.8.0",
		"resend": "^6.9.2",
		"server-only": "^0.0.1",
		"shadcn": "^3.8.5",
		"sonner": "^2.0.7",
		"stripe": "^20.4.1",
		"tailwind-merge": "^3.5.0",
		"tw-animate-css": "^1.4.0",
		"web-haptics": "^0.0.6",
		"ws": "^8.19.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.4",
		"@tailwindcss/postcss": "^4",
		"@types/node": "^20",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"dotenv": "^17.3.1",
		"drizzle-kit": "^0.31.9",
		"tailwindcss": "^4",
		"typescript": "^5"
	}
}
